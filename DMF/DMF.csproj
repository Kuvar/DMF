	  </MauiXaml>
	  <MauiXaml Update="Pages\FavoriteView.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </MauiXaml>
	  <MauiXaml Update="Pages\GetStartedPage.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </MauiXaml>
	  <MauiXaml Update="Pages\HomeView.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </MauiXaml>
