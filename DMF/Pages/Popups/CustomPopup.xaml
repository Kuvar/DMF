<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               x:Class="DMF.Pages.Popups.CustomPopup" Color="Transparent">
    <Border Padding="20"
            WidthRequest="320"
            StrokeShape="RoundRectangle 20">
        <VerticalStackLayout Spacing="16">
            <Label x:Name="PopupName"
                   FontAttributes="Bold"
                   FontSize="18" />
            <BoxView HeightRequest="1" VerticalOptions="Fill" Background="red"/>

            <Label x:Name="PopupMessage" />

            <Button Text="OK" 
                    TextColor="White"
                    Clicked="OnOkClicked"
                    BackgroundColor="{StaticResource DmfRed}" />

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
