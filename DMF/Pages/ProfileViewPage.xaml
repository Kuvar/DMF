<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:converters="clr-namespace:DMF.Converters"
             xmlns:viewModels="clr-namespace:DMF.PageModels"
             BackgroundImageSource="profile_view_bg.jpg"
             xmlns:models="clr-namespace:DMF.Models"
             xmlns:views="clr-namespace:DMF.Pages"
             x:Class="DMF.Pages.ProfileViewPage"
             xmlns:f="clr-namespace:Fonts"
             Shell.NavBarIsVisible="False"
             Title="ProfileViewPage">
    <ContentPage.BindingContext>
        <viewModels:ProfileViewPageModel />
    </ContentPage.BindingContext>
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToSvgConverter x:Key="BoolToSvgConverter"
                                           TrueIcon="selected_radio"
                                           FalseIcon="unselected_radio" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="Root"
          Padding="16,15,16,20"
          RowDefinitions="Auto,*"
          RowSpacing="20">
        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12">
            <Image Grid.Column="0"
                   VerticalOptions="Center"
                   Source="{FontImageSource FontFamily=FluentUI, Glyph={x:Static f:FluentUI.chevron_left_48_regular}, Color={x:StaticResource White}, Size=48}"
                   HeightRequest="24">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}" />
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1"
                   Text="Profile View"
                   FontSize="22"
                   TextColor="White"
                   FontFamily="PoppinsSemiBold"
                   VerticalTextAlignment="Center" />
        </Grid>
        <!-- ================= CONTENT ================= -->
        <VerticalStackLayout Grid.Row="1">
            <Grid ColumnDefinitions="2*,8*">
                <Border Grid.Column="0"
                        HeightRequest="60"
                        WidthRequest="60"
                        Padding="0"
                        StrokeShape="RoundRectangle 35"
                        BackgroundColor="#333">

                    <Image Source="user_profile"
                           Aspect="AspectFill" />
                </Border>
                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center"
                                     Padding="10,0,0,0">
                    <Label FontSize="18"
                           TextColor="White"
                           Text="Bright Motors Delhi"
                           FontFamily="PoppinsRegular"
                           HorizontalTextAlignment="Start" />

                    <Label FontSize="16"
                           TextColor="White"
                           Text="Delhi"
                           FontFamily="PoppinsRegular"
                           HorizontalTextAlignment="Start" />

                </VerticalStackLayout>
            </Grid>
            <VerticalStackLayout Padding="16"
                                 Spacing="12">

                <Label Text="Services"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White" />

                <HorizontalStackLayout Spacing="24">

                    <HorizontalStackLayout VerticalOptions="Center"
                                           Spacing="10">
                        <Image HeightRequest="24"
                               Source="{Binding IsLoanSelected, Converter={StaticResource BoolToSvgConverter}}">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectServiceCommand}"
                                                      CommandParameter="Loan" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label Text="Loan"
                               FontSize="12"
                               TextColor="White"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout VerticalOptions="Center"
                                           Spacing="10">
                        <Image HeightRequest="24"
                               Source="{Binding IsRegistrationSelected, Converter={StaticResource BoolToSvgConverter}}">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectServiceCommand}"
                                                      CommandParameter="Registration" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label FontSize="12" 
                               Text="Registration"
                               TextColor="White"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout VerticalOptions="Center"
                                           Spacing="10">
                        <Image HeightRequest="24"
                               Source="{Binding IsNocSelected, Converter={StaticResource BoolToSvgConverter}}">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectServiceCommand}"
                                                      CommandParameter="NOC" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label Text="NOC"
                               FontSize="12"
                               TextColor="White"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>