<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:DMF.Pages.Controls"
             xmlns:local="clr-namespace:DMF.Pages.Behaviors"
             xmlns:viewModels="clr-namespace:DMF.PageModels"
             BackgroundImageSource="login_bg"
             Shell.NavBarIsVisible="False"
             x:Class="DMF.Pages.LoginPage">
    <Grid RowDefinitions="4*,6*">
        <VerticalStackLayout Grid.Row="1"
                             Padding="24">
            <Label Text="Login with&#10;mobile number"
                   FontSize="22"
                   CharacterSpacing="2"
                   Margin="0,10,0,0"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap"
                   FontFamily="PoppinsRegular"
                   VerticalTextAlignment="Start"
                   HorizontalTextAlignment="Start"
                   TextColor="{StaticResource White}" />

            <VerticalStackLayout Spacing="20">
                <controls:AdvancedEntryView Prefix="+91 -"
                                            DigitsOnly="True"
                                            ReturnType="Next"
                                            EntryMaxLength="10"
                                            x:Name="MobileEntry"
                                            EntryKeyboard="Numeric"
                                            Text="{Binding MobileNumber}"
                                            Placeholder="Enter mobile number"
                                            HasError="{Binding HasMobileError}">
                </controls:AdvancedEntryView>


                <VerticalStackLayout Spacing="0">
                    <Label Text="Name"
                           FontSize="22"
                           FontFamily="PoppinsRegular"
                           TextColor="{StaticResource DmfGrayEA}" />

                    <controls:AdvancedEntryView ReturnType="Done"
                                                DigitsOnly="False"
                                                x:Name="NameEntry"
                                                Text="{Binding Name}"
                                                EntryKeyboard="Default"
                                                HasError="{Binding HasNameError}"
                                                Placeholder="Enter your name" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="Auto,*"
                      VerticalOptions="Center">

                    <!-- Checkbox -->
                    <CheckBox IsChecked="{Binding IsTermsAccepted}"
                              Color="White"
                              VerticalOptions="Start" />

                    <!-- Text -->
                    <Label Grid.Column="1"
                           FontSize="12"
                           LineBreakMode="WordWrap"
                           TextColor="White"
                           FontFamily="PoppinsRegular"
                           Margin="12,0,0,0">

                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="By clicking the checkbox, you agree with " />
                                <Span Text="Terms of Use"
                                      TextColor="{StaticResource DmfRed}"
                                      TextDecorations="Underline" />
                                <Span Text=", " />
                                <Span Text="Privacy Policy"
                                      TextColor="{StaticResource DmfRed}"
                                      TextDecorations="Underline" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>

                <Button Text="GET OTP"
                        FontSize="20"
                        CornerRadius="14"
                        HeightRequest="56"
                        FontAttributes="Bold"
                        IsEnabled="{Binding IsTermsAccepted}"
                        BackgroundColor="{StaticResource DmfGray}"
                        TextColor="{StaticResource DmfBlack08090D}"
                        Command="{Binding NavigateToOTPVerificationCommand}" />

            </VerticalStackLayout>
        </VerticalStackLayout>
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           Color="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Grid.RowSpan="2"
                           IsVisible="{Binding IsBusy}" />
    </Grid>
</ContentPage>