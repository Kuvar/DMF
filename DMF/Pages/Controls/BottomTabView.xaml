<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:converter="clr-namespace:DMF.Converters"
             xmlns:pages="clr-namespace:DMF.Pages.Controls"
             x:Class="DMF.Pages.Controls.BottomTabView"
             xmlns:local="clr-namespace:DMF.Enums"
             xmlns:f="clr-namespace:Fonts"
             x:Name="bottomTab">

    <ContentView.Resources>
        <converter:TabEqualsConverter x:Key="TabEqualsConverter" />
    </ContentView.Resources>

    <Grid Padding="10,0,10,10" BackgroundColor="Transparent">

        <!-- Floating Container -->
        <Border Padding="0"
                HeightRequest="80"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Stroke="{StaticResource Gray100}"
                Background="{StaticResource DmfBlack15171D}"
                StrokeShape="RoundRectangle 10,10,30,30">

            <Grid ColumnDefinitions="*,*,*"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">

                <!-- HOME TAB -->
                <Grid Grid.Column="0">
                    <Border x:Name="HomeBg"
                            WidthRequest="58"
                            HeightRequest="58"
                            StrokeShape="RoundRectangle 30"
                            Background="{StaticResource DmfRed}"
                            IsVisible="{Binding SelectedTab, Source={x:Reference bottomTab}, Converter={StaticResource TabEqualsConverter}, ConverterParameter=Home}" />

                    <Button ImageSource="{FontImageSource FontFamily=FluentUI, Glyph={x:Static f:FluentUI.home_48_regular}, Color={StaticResource White}, Size=48}"
                            Command="{Binding Source={x:Reference bottomTab}, Path=ChangeTabCommand}"
                            CommandParameter="{x:Static local:TabType.Home}"
                            BackgroundColor="Transparent"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HeightRequest="58"
                            WidthRequest="58" />

                </Grid>

                <!-- FAVORITE TAB -->
                <Grid Grid.Column="1">
                    <Border x:Name="FavBg"
                            WidthRequest="58"
                            HeightRequest="58"
                            StrokeShape="RoundRectangle 30"
                            Background="{StaticResource DmfRed}"
                            IsVisible="{Binding SelectedTab, Source={x:Reference bottomTab}, Converter={StaticResource TabEqualsConverter}, ConverterParameter=Favorite}" />

                    <Button ImageSource="{FontImageSource FontFamily=FluentUI, Glyph={x:Static f:FluentUI.heart_48_regular}, Color={StaticResource White}, Size=48}"
                            Command="{Binding Source={x:Reference bottomTab}, Path=ChangeTabCommand}"
                            CommandParameter="{x:Static local:TabType.Favorite}"
                            BackgroundColor="Transparent"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HeightRequest="58"
                            WidthRequest="58" />
                </Grid>

                <!-- PROFILE TAB -->
                <Grid Grid.Column="2">
                    <Border x:Name="ProfileBg"
                            WidthRequest="58"
                            HeightRequest="58"
                            StrokeShape="RoundRectangle 30"
                            Background="{StaticResource DmfRed}"
                            IsVisible="{Binding SelectedTab, Source={x:Reference bottomTab}, Converter={StaticResource TabEqualsConverter}, ConverterParameter=Account}" />

                    <Button ImageSource="{FontImageSource FontFamily=FluentUI, Glyph={x:Static f:FluentUI.person_48_regular}, Color={StaticResource White}, Size=48}"
                            Command="{Binding Source={x:Reference bottomTab}, Path=ChangeTabCommand}"
                            CommandParameter="{x:Static local:TabType.Account}"
                            BackgroundColor="Transparent"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HeightRequest="58"
                            WidthRequest="58" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
