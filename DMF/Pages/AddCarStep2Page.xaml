<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:controls="clr-namespace:DMF.Pages.Controls"
             xmlns:converters="clr-namespace:DMF.Converters"
             BackgroundImageSource="add_car_bg.jpg"
             x:Class="DMF.Pages.AddCarStep2Page"
             xmlns:f="clr-namespace:Fonts"
             Shell.NavBarIsVisible="False">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid x:Name="Root"
          RowSpacing="20"
          Padding="16,15,16,20"
          RowDefinitions="Auto,*,Auto">
        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12">
            <Image Grid.Column="0"
                   VerticalOptions="Center"
                   Source="{FontImageSource FontFamily=FluentUI, Glyph={x:Static f:FluentUI.chevron_left_48_regular}, Color={x:StaticResource White}, Size=48}"
                   HeightRequest="24">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}" />
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1"
                   Text="Add a Car"
                   FontSize="22"
                   TextColor="White"
                   FontFamily="PoppinsSemiBold"
                   VerticalTextAlignment="Center" />

            <Border Padding="0"
                    Grid.Column="2"
                    WidthRequest="40"
                    HeightRequest="40"
                    VerticalOptions="Center"
                    Background="{StaticResource DmfRed}"
                    StrokeShape="RoundRectangle 20,20,20,20">

                <Image Source="home"
                       HeightRequest="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToHomeCommand}" />
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- ================= CONTENT ================= -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="16"
                             Padding="0,20">

            <Label Text="2. Vehicle Condition"
                   FontSize="22"
                   TextColor="White" />

            <controls:AdvancedEntryView Placeholder="Odometer Reading"
                                        Text="{Binding Car.OdometerReading}" />

            <controls:AdvancedPickerView Title="Accident History"
                                         ItemsSource="{Binding YesNoOptions}"
                                         SelectedItem="{Binding Car.AccidentHistory, Converter={StaticResource BoolToYesNoConverter}}" />

            <controls:AdvancedPickerView Title="Service History"
                                         ItemsSource="{Binding YesNoOptions}"
                                         SelectedItem="{Binding Car.ServiceHistory, Converter={StaticResource BoolToYesNoConverter}}" />

            <Label FontSize="22"
                   Text="3. Pricing"
                   TextColor="White" />

            <controls:AdvancedEntryView Placeholder="Price"
                                        Text="{Binding Car.Price}" />


            <controls:AdvancedPickerView Title="Negotiable"
                                         ItemsSource="{Binding YesNoOptions}"
                                         SelectedItem="{Binding Car.IsNegotiable, Converter={StaticResource BoolToYesNoConverter}}" />

        </VerticalStackLayout>

        <Button Text="Next"
                Grid.Row="2"
                TextColor="White"
                Command="{Binding NextStep2Command}"
                BackgroundColor="{StaticResource DmfRed}" />
    </Grid>
</ContentPage>